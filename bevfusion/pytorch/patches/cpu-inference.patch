+def _rotate_boxes_to_corners_2d(boxes):
+    """Convert rotated boxes [x, y, w, l, ry] to 4 corners."""
+    x, y, w, l, ry = boxes[:, 0], boxes[:, 1], boxes[:, 2], boxes[:, 3], boxes[:, 4]
+    cos_ry = torch.cos(ry)
+    sin_ry = torch.sin(ry)
+    hw = w / 2.0
+    hl = l / 2.0
+    dx = torch.stack([hw, hw, -hw, -hw], dim=1)
+    dy = torch.stack([hl, -hl, -hl, hl], dim=1)
+    corners_x = dx * cos_ry.unsqueeze(1) - dy * sin_ry.unsqueeze(1) + x.unsqueeze(1)
+    corners_y = dx * sin_ry.unsqueeze(1) + dy * cos_ry.unsqueeze(1) + y.unsqueeze(1)
+    return torch.stack([corners_x, corners_y], dim=2)  # [N, 4, 2]
+
+
+def _boxes_iou_bev_cpu(boxes_a, boxes_b):
+    """Simple axis-aligned BEV IoU approximation for CPU fallback."""
+    # Use axis-aligned bounding box approximation
+    M = boxes_a.shape[0]
+    N = boxes_b.shape[0]
+
+    # Convert to axis-aligned format: [x1, y1, x2, y2]
+    def to_aa(boxes):
+        x, y, w, l = boxes[:, 0], boxes[:, 1], boxes[:, 2], boxes[:, 3]
+        hw, hl = w / 2, l / 2
+        x1 = x - hw
+        y1 = y - hl
+        x2 = x + hw
+        y2 = y + hl
+        return torch.stack([x1, y1, x2, y2], dim=1)
+
+    aa_a = to_aa(boxes_a)  # [M, 4]
+    aa_b = to_aa(boxes_b)  # [N, 4]
+
+    x1_inter = torch.max(aa_a[:, 0].unsqueeze(1), aa_b[:, 0].unsqueeze(0))
+    y1_inter = torch.max(aa_a[:, 1].unsqueeze(1), aa_b[:, 1].unsqueeze(0))
+    x2_inter = torch.min(aa_a[:, 2].unsqueeze(1), aa_b[:, 2].unsqueeze(0))
+    y2_inter = torch.min(aa_a[:, 3].unsqueeze(1), aa_b[:, 3].unsqueeze(0))
+
+    inter = torch.clamp(x2_inter - x1_inter, min=0) * torch.clamp(y2_inter - y1_inter, min=0)
+
+    area_a = (aa_a[:, 2] - aa_a[:, 0]) * (aa_a[:, 3] - aa_a[:, 1])
+    area_b = (aa_b[:, 2] - aa_b[:, 0]) * (aa_b[:, 3] - aa_b[:, 1])
+    union = area_a.unsqueeze(1) + area_b.unsqueeze(0) - inter
+
+    iou = inter / torch.clamp(union, min=1e-6)
+    return iou
 
 
