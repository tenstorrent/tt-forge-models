+"""Minimal CPU inference test for BEVFusion Camera+LiDAR fusion."""
+
+import os
+import sys
+import warnings
+import time
+
+warnings.filterwarnings("ignore")
+
+import torch
+import numpy as np
+
+sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
+
+from torchpack.utils.config import configs
+from mmcv import Config
+from mmcv.runner import load_checkpoint
+from mmdet3d.models import build_model
+from mmdet3d.utils import recursive_eval
+
+
+def create_dummy_data(batch_size=1, num_cameras=6, img_h=256, img_w=704, num_points=5000):
+    """Create synthetic input data matching nuScenes format."""
+    data = {}
+
+    data["img"] = torch.randn(batch_size, num_cameras, 3, img_h, img_w)
+
+    pts = torch.randn(num_points, 5)
+    pts[:, :3] = pts[:, :3] * 50
+    data["points"] = [pts]
+
+    data["camera2ego"] = torch.eye(4).unsqueeze(0).unsqueeze(0).repeat(batch_size, num_cameras, 1, 1)
+    data["lidar2ego"] = torch.eye(4).unsqueeze(0).repeat(batch_size, 1, 1)
+    data["lidar2camera"] = torch.eye(4).unsqueeze(0).unsqueeze(0).repeat(batch_size, num_cameras, 1, 1)
+    data["lidar2image"] = torch.eye(4).unsqueeze(0).unsqueeze(0).repeat(batch_size, num_cameras, 1, 1)
+    data["camera_intrinsics"] = torch.eye(4).unsqueeze(0).unsqueeze(0).repeat(batch_size, num_cameras, 1, 1)
+    data["camera_intrinsics"][:, :, 0, 0] = 1266.4
+    data["camera_intrinsics"][:, :, 1, 1] = 1266.4
+    data["camera_intrinsics"][:, :, 0, 2] = 816.3
+    data["camera_intrinsics"][:, :, 1, 2] = 491.5
+    data["camera2lidar"] = torch.eye(4).unsqueeze(0).unsqueeze(0).repeat(batch_size, num_cameras, 1, 1)
+    data["img_aug_matrix"] = torch.eye(4).unsqueeze(0).unsqueeze(0).repeat(batch_size, num_cameras, 1, 1)
+    data["lidar_aug_matrix"] = torch.eye(4).unsqueeze(0).repeat(batch_size, 1, 1)
+
+    from mmdet3d.core.bbox import LiDARInstance3DBoxes
+    data["metas"] = [
+        {
+            "token": "dummy_token",
+            "box_type_3d": LiDARInstance3DBoxes,
+        }
+    ]
+
+    return data
+
+
+def main():
+    config_path = "configs/nuscenes/det/transfusion/secfpn/camera+lidar/swint_v0p075/convfuser.yaml"
+    checkpoint_path = "pretrained/bevfusion-det.pth"
+
+    print(f"[1/5] Loading config from: {config_path}")
+    configs.load(config_path, recursive=True)
+    cfg = Config(recursive_eval(configs), filename=config_path)
+
+    print(f"[2/5] Building model...")
+    cfg.model.train_cfg = None
+    model = build_model(cfg.model, test_cfg=cfg.get("test_cfg"))
+    model.eval()
+
+    print(f"[3/5] Loading checkpoint: {checkpoint_path}")
+    ckpt = load_checkpoint(model, checkpoint_path, map_location="cpu")
+
+    if "meta" in ckpt and "CLASSES" in ckpt["meta"]:
+        model.CLASSES = ckpt["meta"]["CLASSES"]
+        print(f"      Classes: {model.CLASSES}")
+
+    num_params = sum(p.numel() for p in model.parameters()) / 1e6
+    print(f"      Model parameters: {num_params:.1f}M")
+
+    print(f"[4/5] Creating dummy input data...")
+    data = create_dummy_data()
+
+    print(f"[5/5] Testing individual components on CPU...")
+    start = time.time()
+    with torch.no_grad():
+        # Test LiDAR voxelization first
+        print("      Testing voxelization...")
+        feats, coords, sizes = model.voxelize(data["points"], "lidar")
+        print(f"      Voxelized: feats={feats.shape}, coords={coords.shape}")
+
+        # Test LiDAR backbone (sparse conv)
+        print("      Testing LiDAR backbone (sparse convolution)...")
+        batch_size_lidar = int(coords[-1, 0].item()) + 1
+        lidar_feat = model.encoders["lidar"]["backbone"](feats, coords, batch_size_lidar, sizes=sizes)
+        print(f"      LiDAR features: {lidar_feat.shape}")
+
+        # Test camera backbone
+        print("      Testing camera backbone...")
+        B, N, C, H, W = data["img"].shape
+        img_flat = data["img"].view(B * N, C, H, W)
+        cam_feat = model.encoders["camera"]["backbone"](img_flat)
+        cam_feat = model.encoders["camera"]["neck"](cam_feat)
+        if not isinstance(cam_feat, torch.Tensor):
+            cam_feat = cam_feat[0]
+        BN, Cf, Hf, Wf = cam_feat.shape
+        cam_feat = cam_feat.view(B, N, Cf, Hf, Wf)
+        print(f"      Camera features: {cam_feat.shape}")
+
+        # Test view transform - use the model's full forward to handle
+        # the depth computation properly
+        print("      Testing full model forward pass...")
+        outputs = model(
+            img=data["img"],
+            points=data["points"],
+            camera2ego=data["camera2ego"],
+            lidar2ego=data["lidar2ego"],
+            lidar2camera=data["lidar2camera"],
+            lidar2image=data["lidar2image"],
+            camera_intrinsics=data["camera_intrinsics"],
+            camera2lidar=data["camera2lidar"],
+            img_aug_matrix=data["img_aug_matrix"],
+            lidar_aug_matrix=data["lidar_aug_matrix"],
+            metas=data["metas"],
+            depths=None,
+        )
+        print(f"      Forward pass result type: {type(outputs)}")
+        if isinstance(outputs, list) and len(outputs) > 0:
+            out = outputs[0]
+            if isinstance(out, dict):
+                for k, v in out.items():
+                    if hasattr(v, "tensor"):
+                        print(f"      {k}: tensor.shape={v.tensor.shape}")
+                    elif hasattr(v, "shape"):
+                        print(f"      {k}: shape={v.shape}")
+                    else:
+                        print(f"      {k}: {type(v)}")
+
+    elapsed = time.time() - start
+    elapsed = time.time() - start
+    print(f"      Forward pass completed in {elapsed:.2f}s")
+
+    if outputs:
+        print(f"      Output type: {type(outputs)}")
+        if isinstance(outputs, list) and len(outputs) > 0:
+            out = outputs[0]
+            if isinstance(out, dict):
+                for k, v in out.items():
+                    if hasattr(v, "shape"):
+                        print(f"      {k}: shape={v.shape}")
+                    elif hasattr(v, "tensor"):
+                        print(f"      {k}: tensor.shape={v.tensor.shape}")
+                    else:
+                        print(f"      {k}: {type(v)}")
+
+    print("\nCPU inference test PASSED!")
+
+
+if __name__ == "__main__":
+    main()
