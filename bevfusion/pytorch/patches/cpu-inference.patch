+def _bev_pool_cpu(feats, coords, B, D, H, W):
+    """Pure-PyTorch scatter-based BEV pooling (works on CPU and GPU)."""
+    C = feats.shape[1]
+    out = feats.new_zeros(B, D, H, W, C)
+
+    # coords columns: [w, d, b, ...] based on the rank formula
+    # rank = w * (W * D * B) + d * (D * B) + b * B + batch
+    # so coords[:, 0]=w, coords[:, 1]=d, coords[:, 2]=b (height?), coords[:, 3]=batch
+    # Actually from the caller in base.py, geom_feats has [batch, depth, height, width]
+    # and the rank formula uses coords[:, 0] * (W*D*B) which suggests first col is h-like
+    # Let's use scatter_add with linear indices matching the rank computation
+
+    batch_idx = coords[:, 3].long()
+    d_idx = coords[:, 1].long()
+    h_idx = coords[:, 2].long()
+    w_idx = coords[:, 0].long()
+
+    valid = (
+        (batch_idx >= 0) & (batch_idx < B) &
+        (d_idx >= 0) & (d_idx < D) &
+        (h_idx >= 0) & (h_idx < H) &
+        (w_idx >= 0) & (w_idx < W)
+    )
+    feats = feats[valid]
+    batch_idx = batch_idx[valid]
+    d_idx = d_idx[valid]
+    h_idx = h_idx[valid]
+    w_idx = w_idx[valid]
+
+    linear_idx = batch_idx * (D * H * W) + d_idx * (H * W) + h_idx * W + w_idx
+    linear_idx = linear_idx.unsqueeze(1).expand_as(feats)
+
+    out_flat = out.reshape(-1, C)
+    out_flat.scatter_add_(0, linear_idx, feats)
+
+    return out
+
+
