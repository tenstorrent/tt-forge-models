@@ -0,0 +1,157 @@
+"""CPU inference on real nuScenes mini data for BEVFusion Camera+LiDAR fusion."""
+
+import os
+import sys
+import warnings
+import time
+import argparse
+
+warnings.filterwarnings("ignore")
+
+import torch
+import numpy as np
+
+sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
+
+from torchpack.utils.config import configs
+from mmcv import Config
+from mmcv.runner import load_checkpoint
+from mmcv.parallel import DataContainer
+from mmdet3d.models import build_model
+from mmdet3d.datasets import build_dataloader, build_dataset
+from mmdet3d.utils import recursive_eval
+from mmdet.datasets import replace_ImageToTensor
+
+
+def unwrap_data_containers(data):
+    """Unwrap DataContainer objects from mmcv dataloader output.
+
+    After collation, DataContainers become nested: DC wraps a list (one element
+    per GPU). We flatten that extra list level so the model receives the same
+    format as it would via MMDataParallel.
+    """
+    result = {}
+    for k, v in data.items():
+        if isinstance(v, DataContainer):
+            inner = v.data
+            if isinstance(inner, list) and len(inner) == 1:
+                inner = inner[0]
+            result[k] = inner
+        elif isinstance(v, (list, tuple)) and len(v) == 1 and isinstance(v[0], DataContainer):
+            inner = v[0].data
+            if isinstance(inner, list) and len(inner) == 1:
+                inner = inner[0]
+            result[k] = inner
+        else:
+            result[k] = v
+    return result
+
+
+def parse_args():
+    parser = argparse.ArgumentParser(description="BEVFusion CPU inference on real data")
+    parser.add_argument(
+        "--config",
+        type=str,
+        default="configs/nuscenes/det/transfusion/secfpn/camera+lidar/swint_v0p075/convfuser.yaml",
+    )
+    parser.add_argument(
+        "--checkpoint",
+        type=str,
+        default="pretrained/bevfusion-det.pth",
+    )
+    parser.add_argument(
+        "--max-samples",
+        type=int,
+        default=5,
+        help="Max number of samples to run (0 = all)",
+    )
+    parser.add_argument("--out", type=str, default=None, help="Output pkl path")
+    return parser.parse_args()
+
+
+def main():
+    args = parse_args()
+
+    print(f"[1/5] Loading config: {args.config}")
+    configs.load(args.config, recursive=True)
+    cfg = Config(recursive_eval(configs), filename=args.config)
+
+    cfg.model.train_cfg = None
+
+    cfg.data.test.test_mode = True
+    samples_per_gpu = cfg.data.test.pop("samples_per_gpu", 1)
+    if samples_per_gpu > 1:
+        cfg.data.test.pipeline = replace_ImageToTensor(cfg.data.test.pipeline)
+
+    print(f"[2/5] Building dataset (nuScenes val)...")
+    dataset = build_dataset(cfg.data.test)
+    print(f"       Dataset size: {len(dataset)} samples")
+
+    data_loader = build_dataloader(
+        dataset,
+        samples_per_gpu=1,
+        workers_per_gpu=0,
+        dist=False,
+        shuffle=False,
+    )
+
+    print(f"[3/5] Building model...")
+    model = build_model(cfg.model, test_cfg=cfg.get("test_cfg"))
+    model.eval()
+
+    print(f"[4/5] Loading checkpoint: {args.checkpoint}")
+    ckpt = load_checkpoint(model, args.checkpoint, map_location="cpu")
+    if "CLASSES" in ckpt.get("meta", {}):
+        model.CLASSES = ckpt["meta"]["CLASSES"]
+    else:
+        model.CLASSES = dataset.CLASSES
+    num_params = sum(p.numel() for p in model.parameters()) / 1e6
+    print(f"       Model params: {num_params:.1f}M, Classes: {model.CLASSES}")
+
+    print(f"[5/5] Running CPU inference...")
+    max_samples = args.max_samples if args.max_samples > 0 else len(dataset)
+    results = []
+
+    for i, data in enumerate(data_loader):
+        if i >= max_samples:
+            break
+
+        data = unwrap_data_containers(data)
+
+        t0 = time.time()
+        with torch.no_grad():
+            result = model(**data)
+        elapsed = time.time() - t0
+        results.extend(result)
+
+        out = result[0]
+        n_det = len(out.get("scores_3d", []))
+        print(f"  Sample {i+1}/{max_samples}: {n_det} detections, {elapsed:.2f}s")
+
+        if n_det > 0:
+            scores = out["scores_3d"]
+            labels = out["labels_3d"]
+            top_k = min(5, n_det)
+            top_scores, top_idx = scores.topk(top_k)
+            class_names = model.CLASSES if hasattr(model, "CLASSES") and model.CLASSES else [str(x) for x in range(10)]
+            for rank, idx in enumerate(top_idx):
+                lbl = labels[idx].item()
+                cls_name = class_names[lbl] if lbl < len(class_names) else f"cls_{lbl}"
+                print(f"    Top-{rank+1}: {cls_name} (score={top_scores[rank]:.3f})")
+
+    print(f"\nDone. Processed {len(results)} samples on CPU.")
+
+    if args.out:
+        import mmcv
+        mmcv.dump(results, args.out)
+        print(f"Results saved to {args.out}")
+
+    if len(results) == len(dataset):
+        eval_results = dataset.evaluate(results, metric="bbox")
+        print(f"\nEvaluation results:\n{eval_results}")
+    elif len(results) > 0:
+        print(f"\nSkipping evaluation ({len(results)}/{len(dataset)} samples processed)")
+
+
+if __name__ == "__main__":
+    main()
